{
  "name": "ai-article-summarizer",
  "version": "2.2.0",
  "private": true,
  "license": "Apache-2.0",
  "author": "Andrea Bonacci (https://github.com/AndreaBonn)",
  "description": "Firefox Extension to summarize web articles using AI (Groq, OpenAI, Claude, Gemini)",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "start:firefox": "web-ext run --source-dir dist",
    "build:xpi": "vite build && web-ext build --source-dir dist --artifacts-dir web-ext-artifacts",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.1",
    "vite": "^8.0.7",
    "vitest": "^4.1.4",
    "web-ext": "^8.4.0"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "jspdf": "^4.2.1",
    "lz-string": "^1.5.0",
    "pdfjs-dist": "^5.6.205"
  },
  "overrides": {
    "rollup": ">=2.80.0"
  }
}
