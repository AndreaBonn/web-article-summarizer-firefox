{
  "manifest_version": 3,
  "name": "AI Article Summarizer",
  "version": "2.2.0",
  "description": "Riassumi articoli web con AI (Groq, OpenAI, Claude, Gemini) - Ottieni punti chiave e risparmia tempo",
  "browser_specific_settings": {
    "gecko": {
      "id": "ai-article-summarizer@example.com",
      "strict_min_version": "109.0"
    }
  },
  "permissions": ["activeTab", "storage", "alarms"],
  "host_permissions": [
    "https://api.groq.com/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "scripts": ["src/background/service-worker.js"],
    "type": "module"
  },
  "action": {
    "default_popup": "src/pages/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "src/pages/options/options.html",
  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "exclude_matches": ["https://accounts.google.com/*", "https://*.banking.com/*"],
      "js": ["src/content/content-script.js"],
      "css": ["src/content/content-script.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "default-src 'none'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self'; font-src 'self'; object-src 'none'; img-src 'self' data:; media-src 'none'; connect-src https://api.groq.com https://api.openai.com https://api.anthropic.com https://generativelanguage.googleapis.com; frame-src https:"
  },
  "web_accessible_resources": [
    {
      "resources": ["workers/pdf.worker.min.js"],
      "matches": ["https://*/*"]
    }
  ]
}
